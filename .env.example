# ── Required ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here

# ── Environment ───────────────────────────────────────────────────────────────
DEBUG=False

# Leave blank — Railway injects RAILWAY_PUBLIC_DOMAIN automatically.
# Add your custom domain here if you have one:
# ALLOWED_HOSTS=api.zabroad.com

# Set by Railway automatically when Postgres plugin is added — do NOT set manually:
# DATABASE_URL=postgresql://...

# ── CORS ─────────────────────────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=https://zabroad.com

# ── Media Storage (Cloudflare R2 or AWS S3) ───────────────────────────────────
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=zabroad-media
# AWS_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=media.zabroad.com

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Stripe (optional) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
